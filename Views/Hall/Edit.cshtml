@model MovieTicketAppFinal.Models.Hall
@{
    ViewData["Title"] = "Edit Hall";
    var theaters = ViewBag.Theaters as List<MovieTicketAppFinal.Models.Theater>;
}
<h1>Edit Hall</h1>
<div asp-validation-summary="All" class="text-danger" style="margin-bottom:1rem;"></div>
<div class="form-card">
    <form method="post">
        <input type="hidden" name="HallId" value="@Model.HallId" />
        <div class="form-group">
            <label>Hall ID</label>
            <input type="number" value="@Model.HallId" disabled />
        </div>
        <div class="form-group">
            <label>Theatre <span style="color:red;">*</span></label>
            <select name="TheatreId" required>
                <option value="">-- Select Theatre --</option>
                @if (theaters != null)
                {
                    @foreach (var t in theaters)
                    {
                        if (t.TheatreId == Model.TheatreId)
                        {
                            <option value="@t.TheatreId" selected>@t.TheatreName</option>
                        }
                        else
                        {
                            <option value="@t.TheatreId">@t.TheatreName</option>
                        }
                    }
                }
            </select>
        </div>
        <div class="form-group">
            <label>Name</label>
            <input type="text" name="HallName" value="@Model.HallName" required />
        </div>
        <div class="form-group">
            <label>Capacity</label>
            <input type="number" name="HallCapacity" value="@Model.HallCapacity" min="1" />
        </div>
        <div class="actions">
            <button type="submit" class="btn btn-primary">Update</button>
            <a href="/Hall" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>