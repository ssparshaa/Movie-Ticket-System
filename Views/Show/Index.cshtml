@model List<MovieTicketAppFinal.Models.Show>
@{
    ViewData["Title"] = "Showtimes";
    var movieNames = ViewBag.MovieNames as Dictionary<int, string>;
    var hallNames = ViewBag.HallNames as Dictionary<int, string>;
    var policyByShow = ViewBag.PolicyByShow as Dictionary<int, string>;
}
<div class="top-bar">
    <h1>Showtimes</h1>
    <a href="/Show/Create" class="btn btn-primary">+ Add Showtime</a>
</div>
@if (TempData["Error"] != null)
{
    <p style="color:red;font-weight:bold;margin-bottom:1rem;">@TempData["Error"]</p>
}
<table>
    <thead>
    <tr><th>ID</th><th>Movie</th><th>Hall</th><th>Show Timing</th><th>Duration</th><th>Ticket Policy</th><th>Actions</th></tr>
    </thead>
    <tbody>
    @foreach (var s in Model)
    {
        <tr>
            <td>@s.ShowId</td>
            <td>@(movieNames != null && movieNames.ContainsKey(s.MovieId) ? movieNames[s.MovieId] : "-")</td>
            <td>@(hallNames != null && hallNames.ContainsKey(s.HallId) ? hallNames[s.HallId] : "-")</td>
            <td>@(s.ShowTiming.HasValue ? s.ShowTiming.Value.ToString("MMM dd, yyyy HH:mm") : "-")</td>
            <td>@(s.ShowDuration.HasValue ? s.ShowDuration + " min" : "-")</td>
            <td>@(policyByShow != null && policyByShow.ContainsKey(s.ShowId) ? policyByShow[s.ShowId] : "-")</td>
            <td class="actions">
                <a href="/Show/Edit/@s.ShowId" class="btn btn-secondary">Edit</a>
                <form method="post" action="/Show/Delete/@s.ShowId" style="display:inline">
                    <button type="submit" class="btn btn-danger" onclick="return confirm('Delete this show?')">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>