@model MovieTicketAppFinal.Models.Show
@{
    ViewData["Title"] = "Edit Showtime";
    var movies = ViewBag.Movies as List<MovieTicketAppFinal.Models.Movie>;
    var halls = ViewBag.Halls as List<MovieTicketAppFinal.Models.Hall>;
    var policies = ViewBag.Policies as List<MovieTicketAppFinal.Models.TicketPolicy>;
    int currentPolicyId = ViewBag.CurrentPolicyId ?? 0;
}
<h1>Edit Showtime #@Model.ShowId</h1>
<div asp-validation-summary="All" class="text-danger" style="margin-bottom:1rem;"></div>
<div class="form-card">
    <form method="post">
        <input type="hidden" name="ShowId" value="@Model.ShowId" />
        <div class="form-group">
            <label>Show ID</label>
            <input type="number" value="@Model.ShowId" disabled />
        </div>
        <div class="form-group">
            <label>Movie <span style="color:red;">*</span></label>
            <select name="MovieId" required>
                <option value="">-- Select Movie --</option>
                @if (movies != null)
                {
                    @foreach (var m in movies)
                    {
                        if (m.MovieId == Model.MovieId)
                        {
                            <option value="@m.MovieId" selected>@m.MovieName</option>
                        }
                        else
                        {
                            <option value="@m.MovieId">@m.MovieName</option>
                        }
                    }
                }
            </select>
        </div>
        <div class="form-group">
            <label>Hall <span style="color:red;">*</span></label>
            <select name="HallId" required>
                <option value="">-- Select Hall --</option>
                @if (halls != null)
                {
                    @foreach (var h in halls)
                    {
                        if (h.HallId == Model.HallId)
                        {
                            <option value="@h.HallId" selected>@h.HallName</option>
                        }
                        else
                        {
                            <option value="@h.HallId">@h.HallName</option>
                        }
                    }
                }
            </select>
        </div>
        <div class="form-group">
            <label>Ticket Policy</label>
            <select name="ticketPolicyId">
                @if (currentPolicyId == 0)
                {
                    <option value="0" selected>-- No Policy --</option>
                }
                else
                {
                    <option value="0">-- No Policy --</option>
                }
                @if (policies != null)
                {
                    @foreach (var p in policies)
                    {
                        if (p.TicketPolicyId == currentPolicyId)
                        {
                            <option value="@p.TicketPolicyId" selected>@p.TicketPaymentPolicy — Base: Rs @p.TicketBasePrice | Price: Rs @p.TicketPolicyPrice</option>
                        }
                        else
                        {
                            <option value="@p.TicketPolicyId">@p.TicketPaymentPolicy — Base: Rs @p.TicketBasePrice | Price: Rs @p.TicketPolicyPrice</option>
                        }
                    }
                }
            </select>
        </div>
        <div class="form-group">
            <label>Show Timing</label>
            <input type="datetime-local" name="ShowTiming" value="@(Model.ShowTiming?.ToString("yyyy-MM-ddTHH:mm") ?? "")" />
        </div>
        <div class="form-group">
            <label>Duration (minutes)</label>
            <input type="number" name="ShowDuration" value="@Model.ShowDuration" />
        </div>
        <div class="actions">
            <button type="submit" class="btn btn-primary">Update</button>
            <a href="/Show" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>