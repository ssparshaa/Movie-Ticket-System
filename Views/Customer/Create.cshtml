@model MovieTicketAppFinal.Models.Customer
@{ ViewData["Title"] = "Add Customer"; }
<h1>Add Customer</h1>
<div asp-validation-summary="All" class="text-danger" style="margin-bottom:1rem;"></div>
<div class="form-card">
    <form method="post">
        <div class="form-group">
            <label>Customer ID</label>
            <input type="number" name="CustomerId" id="CustomerId" value="@Model.CustomerId" required />
            <span id="id-error" style="color:red;font-size:0.85rem;display:none;">This Customer ID already exists.</span>
        </div>
        <div class="form-group"><label>Name</label><input type="text" name="CustomerName" value="@Model.CustomerName" required /></div>
        <div class="form-group"><label>Address</label><input type="text" name="CustomerAddress" value="@Model.CustomerAddress" /></div>
        <div class="form-group"><label>Contact Number</label><input type="text" name="CustomerContactNumber" value="@Model.CustomerContactNumber" /></div>
        <div class="actions">
            <button type="submit" class="btn btn-primary">Save</button>
            <a href="/Customer" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

<script>
document.querySelector('form').addEventListener('submit', async function(e) {
    const id = document.getElementById('CustomerId').value;
    if (!id) return;
    const resp = await fetch('/Customer/CheckId?id=' + id);
    const exists = await resp.json();
    const errSpan = document.getElementById('id-error');
    if (exists) {
        e.preventDefault();
        errSpan.style.display = 'block';
    } else {
        errSpan.style.display = 'none';
    }
});
</script>