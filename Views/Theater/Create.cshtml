@{ ViewData["Title"] = "Add Theater"; }
<h1>Add Theater</h1>
<div asp-validation-summary="All" class="text-danger" style="margin-bottom:1rem;"></div>
<div class="form-card">
    <form method="post">
        <div class="form-group"><label>Theater ID</label><input type="number" name="TheatreId" required /></div>
        <div class="form-group"><label>Name</label><input type="text" name="TheatreName" required /></div>
        <div class="form-group"><label>Address</label><input type="text" name="TheatreAddress" /></div>
        <div class="actions">
            <button type="submit" class="btn btn-primary">Save</button>
            <a href="/Theater" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>