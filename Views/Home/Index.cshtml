@{
    ViewData["Title"] = "Dashboard";
    int purchased = ViewBag.Purchased ?? 0;
    int booked = ViewBag.Booked ?? 0;
    int cancelled = ViewBag.Cancelled ?? 0;
    int total = ViewBag.TotalTickets ?? 0;
    int purchasedPct = total > 0 ? (int)Math.Round(purchased * 100.0 / total) : 0;
    int bookedPct    = total > 0 ? (int)Math.Round(booked    * 100.0 / total) : 0;
    int cancelledPct = total > 0 ? (int)Math.Round(cancelled * 100.0 / total) : 0;
    decimal revenue = ViewBag.TotalRevenue ?? 0m;
    var revenueByPolicy = ViewBag.RevenueByPolicy as List<KeyValuePair<string, decimal>> ?? new List<KeyValuePair<string, decimal>>();
    decimal maxRevenue = revenueByPolicy.Any() ? revenueByPolicy.Max(x => x.Value) : 1;
}

<style>
    .dashboard { padding: 0; }
    .hero {
        background: linear-gradient(135deg, #0d0d0d 0%, #1a0505 50%, #0d0d0d 100%);
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 3rem 2rem;
        text-align: center;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }
    .hero::before {
        content: '';
        position: absolute;
        top: -50%; left: -50%;
        width: 200%; height: 200%;
        background: radial-gradient(circle, rgba(230,57,70,0.08) 0%, transparent 60%);
        pointer-events: none;
    }
    .hero h1 { font-family: 'Bebas Neue', sans-serif; font-size: 4rem; letter-spacing: 4px; color: #fff; margin-bottom: 0.5rem; }
    .hero h1 span { color: #e63946; }
    .hero p { color: #888; font-size: 1.1rem; margin-bottom: 2rem; }
    .hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }
    .stat-card {
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 10px;
        padding: 1.2rem 1rem;
        text-align: center;
        transition: border-color 0.2s, transform 0.2s;
    }
    .stat-card:hover { border-color: #e63946; transform: translateY(-3px); }
    .stat-num { font-family: 'Bebas Neue', sans-serif; font-size: 2.2rem; color: #e63946; line-height: 1; }
    .stat-label { color: #888; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-top: 0.3rem; }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem; }
    @@media (max-width: 800px) { .grid-2 { grid-template-columns: 1fr; } }

    .card {
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 10px;
        padding: 1.5rem;
    }
    .card h3 { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; letter-spacing: 2px; margin-bottom: 1.2rem; color: #e63946; }

    .donut-container { display: flex; align-items: center; justify-content: center; gap: 2rem; flex-wrap: wrap; }
    .donut-legend { display: flex; flex-direction: column; gap: 0.8rem; }
    .legend-item { display: flex; align-items: center; gap: 0.6rem; font-size: 0.85rem; color: #ccc; }
    .legend-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
    .legend-count { font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem; color: #fff; }

    .chart-bar-h { margin-bottom: 0.8rem; }
    .chart-bar-h .cb-label { font-size: 0.78rem; color: #aaa; margin-bottom: 4px; display: flex; justify-content: space-between; }
    .chart-bar-h .cb-track { background: #2a2a2a; border-radius: 6px; height: 26px; position: relative; overflow: hidden; }
    .chart-bar-h .cb-fill { height: 100%; border-radius: 6px; transition: width 1s ease; display: flex; align-items: center; padding-left: 10px; font-size: 0.75rem; color: #fff; font-weight: 600; min-width: 40px; }
    .rev-total { margin-top: 1.2rem; padding-top: 1rem; border-top: 1px solid #2a2a2a; display: flex; justify-content: space-between; align-items: center; }
    .rev-total span { font-size: 0.85rem; color: #888; }
    .rev-total strong { font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; color: #4caf50; }

    .quick-links { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; }
    .quick-link {
        display: flex; align-items: center; gap: 0.6rem;
        background: #111; border: 1px solid #2a2a2a;
        border-radius: 8px; padding: 0.7rem 0.9rem;
        text-decoration: none; color: #ccc; font-size: 0.85rem;
        transition: all 0.2s;
    }
    .quick-link:hover { border-color: #e63946; color: #fff; background: #1a0505; }

    .complex-section h2 { font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; letter-spacing: 2px; margin-bottom: 1rem; color: #888; }
    .complex-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
    @@media (max-width: 700px) { .complex-grid { grid-template-columns: 1fr; } }
    .complex-card {
        background: linear-gradient(135deg, #1a0505, #1a1a1a);
        border: 1px solid #3a1a1a;
        border-radius: 10px;
        padding: 1.5rem;
        text-decoration: none;
        color: #f0f0f0;
        transition: all 0.2s;
        display: block;
    }
    .complex-card:hover { border-color: #e63946; transform: translateY(-3px); }
    .complex-card h4 { font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem; letter-spacing: 1px; color: #e63946; margin-bottom: 0.3rem; }
    .complex-card p { font-size: 0.78rem; color: #888; }
</style>

<div class="dashboard">

    <!-- HERO -->
    <div class="hero">
        <h1>KUMARI <span>CINEMAS</span></h1>
        <p>Ticket Management System — Admin Dashboard</p>
        <div class="hero-btns">
            <a href="/Movie" class="btn btn-primary">Manage Movies</a>
            <a href="/Ticket" class="btn btn-secondary">Manage Tickets</a>
            <a href="/Customer" class="btn btn-secondary">Manage Customers</a>
        </div>
    </div>

    <!-- STATS -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-num">@ViewBag.TotalMovies</div>
            <div class="stat-label">Movies</div>
        </div>
        <div class="stat-card">
            <div class="stat-num">@ViewBag.TotalCustomers</div>
            <div class="stat-label">Customers</div>
        </div>
        <div class="stat-card">
            <div class="stat-num">@ViewBag.TotalTickets</div>
            <div class="stat-label">Tickets</div>
        </div>
        <div class="stat-card">
            <div class="stat-num">@ViewBag.TotalTheaters</div>
            <div class="stat-label">Theaters</div>
        </div>
        <div class="stat-card">
            <div class="stat-num">@ViewBag.TotalHalls</div>
            <div class="stat-label">Halls</div>
        </div>
        <div class="stat-card">
            <div class="stat-num">@ViewBag.TotalShows</div>
            <div class="stat-label">Shows</div>
        </div>
    </div>

    <!-- CHARTS: Donut + Revenue -->
    <div class="grid-2">

        <!-- Donut Chart - Ticket Status -->
        <div class="card">
            <h3>Ticket Status Breakdown</h3>
            <div class="donut-container">
                @{
                    int dSize = 170;
                    double dRadius = 62;
                    double dStroke = 20;
                    double dCircum = 2 * Math.PI * dRadius;
                    double pLen = purchasedPct / 100.0 * dCircum;
                    double bLen = bookedPct / 100.0 * dCircum;
                    double cLen = cancelledPct / 100.0 * dCircum;
                    double pOff = 0;
                    double bOff = pLen;
                    double cOff = pLen + bLen;
                }
                <svg width="@dSize" height="@dSize" viewBox="0 0 @dSize @dSize">
                    <!-- Background ring -->
                    <circle cx="@(dSize/2)" cy="@(dSize/2)" r="@dRadius" fill="none" stroke="#2a2a2a" stroke-width="@dStroke"/>
                    @if (purchasedPct > 0)
                    {
                        <circle cx="@(dSize/2)" cy="@(dSize/2)" r="@dRadius" fill="none" stroke="#4caf50" stroke-width="@dStroke"
                                stroke-dasharray="@pLen @dCircum"
                                stroke-dashoffset="-@pOff"
                                transform="rotate(-90 @(dSize/2) @(dSize/2))"
                                stroke-linecap="round"/>
                    }
                    @if (bookedPct > 0)
                    {
                        <circle cx="@(dSize/2)" cy="@(dSize/2)" r="@dRadius" fill="none" stroke="#ffc107" stroke-width="@dStroke"
                                stroke-dasharray="@bLen @dCircum"
                                stroke-dashoffset="-@bOff"
                                transform="rotate(-90 @(dSize/2) @(dSize/2))"
                                stroke-linecap="round"/>
                    }
                    @if (cancelledPct > 0)
                    {
                        <circle cx="@(dSize/2)" cy="@(dSize/2)" r="@dRadius" fill="none" stroke="#e63946" stroke-width="@dStroke"
                                stroke-dasharray="@cLen @dCircum"
                                stroke-dashoffset="-@cOff"
                                transform="rotate(-90 @(dSize/2) @(dSize/2))"
                                stroke-linecap="round"/>
                    }
                    <text x="@(dSize/2)" y="@(dSize/2 - 8)" text-anchor="middle" fill="#fff" font-family="Bebas Neue" font-size="32">@total</text>
                    <text x="@(dSize/2)" y="@(dSize/2 + 14)" text-anchor="middle" fill="#888" font-size="11" letter-spacing="2">TICKETS</text>
                </svg>
                <div class="donut-legend">
                    <div class="legend-item">
                        <div class="legend-dot" style="background:#4caf50;"></div>
                        <span>Purchased</span>
                        <span class="legend-count">@purchased (@purchasedPct%)</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-dot" style="background:#ffc107;"></div>
                        <span>Booked</span>
                        <span class="legend-count">@booked (@bookedPct%)</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-dot" style="background:#e63946;"></div>
                        <span>Cancelled</span>
                        <span class="legend-count">@cancelled (@cancelledPct%)</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Revenue by Policy -->
        <div class="card">
            <h3>Revenue by Ticket Policy</h3>
            @if (revenueByPolicy.Any())
            {
                @foreach (var item in revenueByPolicy)
                {
                    int pct = maxRevenue > 0 ? (int)Math.Round((double)(item.Value / maxRevenue * 100)) : 0;
                    string barColor = item.Key.Contains("VIP") ? "#e63946" :
                                      item.Key.Contains("Premium") ? "#ff6b6b" :
                                      item.Key.Contains("Holiday") ? "#ffc107" :
                                      item.Key.Contains("Weekend") ? "#4caf50" :
                                      item.Key.Contains("Student") ? "#64b5f6" :
                                      item.Key.Contains("Matinee") ? "#81c784" :
                                      item.Key.Contains("Early") ? "#aed581" :
                                      item.Key.Contains("Friday") ? "#ffb74d" :
                                      item.Key.Contains("New Release") ? "#ce93d8" : "#4caf50";
                    <div class="chart-bar-h">
                        <div class="cb-label">
                            <span>@item.Key</span>
                            <span style="color:#fff;font-weight:600;">Rs @item.Value.ToString("N0")</span>
                        </div>
                        <div class="cb-track">
                            <div class="cb-fill" style="width:@(pct)%;background:@barColor;"></div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p style="color:#666;font-size:0.85rem;">No revenue data yet.</p>
            }
            <div class="rev-total">
                <span>Total Revenue</span>
                <strong>Rs @revenue.ToString("N0")</strong>
            </div>
        </div>
    </div>

    <!-- QUICK ACCESS + COMPLEX REPORTS -->
    <div class="grid-2">
        <div class="card">
            <h3>Quick Access</h3>
            <div class="quick-links">
                <a href="/Movie/Create" class="quick-link"><span>+</span> Add Movie</a>
                <a href="/Customer/Create" class="quick-link"><span>+</span> Add Customer</a>
                <a href="/Ticket/Create" class="quick-link"><span>+</span> Add Ticket</a>
                <a href="/Theater/Create" class="quick-link"><span>+</span> Add Theater</a>
                <a href="/Hall/Create" class="quick-link"><span>+</span> Add Hall</a>
                <a href="/Show/Create" class="quick-link"><span>+</span> Add Show</a>
                <a href="/TicketPolicy" class="quick-link"><span>$</span> Ticket Policies</a>
                <a href="/Ticket/TicketOverview" class="quick-link"><span>@("📋")</span> Ticket Overview</a>
            </div>
        </div>

        <div class="complex-section">
            <h2>Complex Reports</h2>
            <div style="display:flex;flex-direction:column;gap:1rem;">
                <a href="/Complex/UserTicket" class="complex-card">
                    <h4>User Ticket History</h4>
                    <p>View all tickets purchased by a customer in the last 6 months</p>
                </a>
                <a href="/Complex/TheaterMovie" class="complex-card">
                    <h4>Theater Movie Showtimes</h4>
                    <p>Browse all movies and showtimes for any selected theater</p>
                </a>
                <a href="/Complex/OccupancyPerformer" class="complex-card">
                    <h4>Top Occupancy Performers</h4>
                    <p>Find top 3 halls with highest seat occupancy for any movie</p>
                </a>
            </div>
        </div>
    </div>

</div>